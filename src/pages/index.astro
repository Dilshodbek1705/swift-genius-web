---
// src/pages/index.astro
export const prerender = false;

import { getLang } from '../i18n/index.ts';
import type { Locale } from '../i18n/index.ts';

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Mentor from '../components/Mentor.astro';
import Mission from '../components/Mission.astro';
import Curriculum from '../components/Curriculum.astro';
import FinalPicture from '../components/FinalPicture.astro';
import ModularArchitecture from '../components/ModularArchitecture.astro';
import Outcome from '../components/Outcome.astro';
import FinalCta from '../components/FinalCta.astro';
import Faq from '../components/Faq.astro';
import SiteFooter from '../components/SiteFooter.astro';

// --- Til aniqlash (Cookie → fallback uz) ---
const cookieLang = Astro.cookies.get('lang')?.value;
const locale: Locale = (cookieLang === 'en' || cookieLang === 'uz') ? cookieLang : 'uz';
const t = getLang(locale);
const isEn = locale === 'en';
---

<BaseLayout locale={locale}>
  <Navbar t={t} isEn={isEn} />
  <Hero t={t} />
  <Mentor t={t} />
  <Mission t={t} />
  <Curriculum t={t} />
  <FinalPicture t={t} />
  <ModularArchitecture t={t} />
  <Outcome t={t} />
  <FinalCta />
  <Faq t={t} />
  <SiteFooter t={t} />
</BaseLayout>
