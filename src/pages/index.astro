---
// src/pages/index.astro
export const prerender = false;  // ← shu qatorni QO'SHING

import '../styles/global.css';
import { getLang } from '../i18n/index.ts';
import type { Locale } from '../i18n/index.ts'; 
import '../styles/global.css';
import { getLang } from '../i18n/index.ts';
import type { Locale } from '../i18n/index.ts';

// --- Til aniqlash (Cookie → fallback uz) ---
const cookieLang = Astro.cookies.get('lang')?.value;
const locale: Locale = (cookieLang === 'en' || cookieLang === 'uz') ? cookieLang : 'uz';
const t = getLang(locale);
const isEn = locale === 'en';


// --- Barcha ma'lumotlar ---
const modules = [
  {
    num: '01',
    category: 'SwiftUI Foundations',
    title: t.modules[0].title,
    subsections: [
      {
        head: 'UI Elements & Modifiers',
        items: ['Text, Image, Button, Spacer', 'VStack, HStack, ZStack', 'padding, frame, alignment', 'background, overlay']
      },
      {
        head: t.modules[0].subs[0],
        items: ['@State, @Binding, @Bindable', '@StateObject, @ObservedObject', '@ObservableObject, @Published', '@EnvironmentObject, @Environment']
      },
      {
        head: t.modules[0].subs[1],
        items: ['List, ScrollView, ForEach', 'LazyVStack, LazyHStack', 'CustomView, ViewModifier']
      },
      {
        head: 'Navigation & Presentation',
        items: ['NavigationStack, NavigationPath', 'navigationDestination', 'sheet, fullScreenCover, Alert, Custom modal']
      }
    ]
  },
  {
    num: '02',
    category: 'Application Structure',
    title: t.modules[1].title,
    subsections: [
      {
        head: "App Architecture & Lifecycle",
        items: ["App protocol, @main", "Scene, WindowGroup", "UIKit AppDelegate implementation", t.modules[1].subs[0]]
      },
      {
        head: "Application Flow Architecture",
        items: ["RootView logic & Navigation State", "App Flow Controller (Splash → Auth → Main)", "Modular Feature Flows", "Deep Linking foundations"]
      }
    ]
  },
  {
    num: '03',
    category: 'Architecture',
    title: 'MVVM Architecture',
    subsections: [
      {
        head: "MVVM Architecture",
        items: ["View, ViewModel, Model Roles", "Business Logic Separation", "Data Binding Techniques", "Separation of Concerns (SoC)"]
      }
    ]
  },
  {
    num: '04',
    category: 'Software Engineering',
    title: 'Dependency Injection & POP',
    subsections: [
      {
        head: "Dependency Injection (DI)",
        items: ["Dependency Injection (DI)", "Loose Coupling principles", "DI Container architecture", "Service registration & resolution"]
      },
      {
        head: "Protocol-Oriented Programming (POP)",
        items: ["Abstraction & Interface Design", "Decoupling techniques", "Enhanced Testability architecture"]
      }
    ]
  },
  {
    num: '05',
    category: 'Global Architecture',
    title: 'Global Managers & SOLID',
    subsections: [
      {
        head: "Global Managers & Service Architecture",
        items: ["Composite & Delegation patterns", "Decoupling Massive Managers", "SOLID Principles application", "Environment Dependency Injection"]
      }
    ]
  },
  {
    num: '06',
    category: 'Business Logic',
    title: t.modules[5].title,
    subsections: [
      {
        head: "Interactor & Business Logic Architecture",
        items: ["System Design Foundations", "Domain Logic Separation", "ViewModel to Interactor Interaction", "Decoupling View Logic from Business Logic"]
      },
      {
        head: t.modules[5].subs[0],
        items: ["Global Business Layer (Centralized Logic)", "Manager Integration & Data Flow", "Service Management & Abstraction"]
      },
      {
        head: "CoreInteractor: Refactoring",
        items: ["Interface Segregation", "Breaking down Monolithic Logic", "Dependency Optimization"]
      }
    ]
  },
  {
    num: '07',
    category: 'Core Application',
    title: 'CoreBuilder & Composition Root',
    subsections: [
      {
        head: "CoreBuilder & Composition Root",
        items: ["Composition Root Pattern", "Centralized Component Initialization", "Object Graph Construction"]
      },
      {
        head: "CoreBuilder: Refactoring",
        items: ["Composition Root Optimization", "Architecture Simplification", "Streamlining Dependency Assembly"]
      }
    ]
  },
  {
    num: '08',
    category: 'Navigation Architecture',
    title: 'CoreRouter & Routing Patterns',
    subsections: [
      {
        head: "Navigation Architecture & CoreRouter",
        items: ["CoreRouter Architecture", "ViewModel to Router Communication", "Decoupling Navigation from UI"]
      },
      {
        head: "Navigation Refactoring",
        items: ["Navigation Logic Centralization", "Global Router Migration Strategy", "Dynamic Flow Management"]
      }
    ]
  },
  {
    num: '09',
    category: 'Environment',
    title: 'Environment & Build Configuration',
    subsections: [
      {
        head: "Environment & Build Configuration",
        items: ["Dev, Release & Mock Schemes", "Build Configuration Management", "Scheme-based Environment Switching"]
      }
    ]
  },
  {
    num: '10',
    category: 'Production Features',
    title: t.modules[9].title,
    subsections: [
      {
        head: "Logging & Diagnostics",
        items: ["Centralized AppLogger", "Diagnostic Log Levels", "Unified Logging Strategy"]
      },
      {
        head: "Analytics & Crashlytics",
        items: ["Firebase & Mixpanel Integration", "Facade Pattern for Analytics", "Behavioral Tracking events"]
      },
      {
        head: t.modules[9].subs[0],
        items: ["Privacy-preserving UI (Blur Overlay)", "DeepLink Security", "Sensitive Data Protection"]
      },
      {
        head: "Language & Theme Architecture",
        items: ["Scalable Localization", "AppLocalModifier & AppThemeModifier", "Dynamic Environment Sync"]
      }
    ]
  },
  {
    num: '11',
    category: 'Advanced Engineering',
    title: 'Modular Architecture & RIBs',
    subsections: [
      {
        head: "Architectural Decomposition",
        items: ["Modular Architecture (Feature separation)", "RIBs (Router, Interactor, Builder)", "System Design for Large-Scale"]
      },
      {
        head: "Scalability & Isolation",
        items: ["Decoupling Feature Modules", "Dependency Management in Modules", "Independent Feature Lifecycle"]
      }
    ]
  },
  {
    num: '12',
    category: 'Quality Assurance',
    title: t.modules[11].title,
    subsections: [
      {
        head: "Unit Testing & QA",
        items: ["Isolated Business Logic verification", "Mock Services & Data Stubbing", "ViewModel State testing"]
      },
      {
        head: "UI Testing",
        items: ["XCUITest Framework", "Automated UI Flow Verification", "Multi-screen Navigation Testing"]
      }
    ]
  }
];

const months = [
  { name: t.months[0], items: modules.slice(0, 4) },
  { name: t.months[1], items: modules.slice(4, 8) },
  { name: t.months[2], items: modules.slice(8, 12) }
];

const mentorProjects = [
  { name: 'MyBank UZ',       logo: '/mybank_logo.png',        href: 'https://apps.apple.com/uz/app/mybank-uz/id6503429804',                           badge: null },
  { name: 'Milliy Business', logo: '/milliy_logo.png',        href: 'https://apps.apple.com/uz/app/milliy-business/id6742812650',                      badge: null },
  { name: 'Sello',           logo: '/sello_logo.png',         href: 'https://apps.apple.com/uz/app/sello-pay-payments-transfers/id1603818062',          badge: null },
  { name: 'SwiftGenius',     logo: '/swiftGenius_logo.png',   href: 'https://apps.apple.com/uz/app/swiftgenius/id6759780139',                           badge: null },
  { name: 'MyBank Business', logo: '/mybank_business.png',    href: null,                                                                               badge: t.mentor.underDev },
];
---

<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />

  <title>SwiftGenius — Professional iOS Engineering & Architecture</title>
  <meta name="title"       content="SwiftGenius — Professional iOS Engineering & Architecture" />
  <meta name="description" content="iOS muhandisligi va arxitektura: Professional darajadagi chuqurlashtirilgan o'quv dasturi." />

  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="https://swiftgenius.uz/" />
  <meta property="og:title"       content="SwiftGenius — Professional iOS Engineering & Architecture" />
  <meta property="og:description" content="Swift va SwiftUI: Yuqori darajadagi dasturiy arxitektura hamda yirik loyihalar uchun muhandislik yondashuvi." />
  <meta property="og:image"       content="https://swiftgenius.uz/summery_image.png" />

  <meta property="twitter:card"        content="summary_large_image" />
  <meta property="twitter:url"         content="https://swiftgenius.uz/" />
  <meta property="twitter:title"       content="SwiftGenius — Professional iOS Engineering & Architecture" />
  <meta property="twitter:description" content="Swift va SwiftUI: Yuqori darajadagi dasturiy arxitektura hamda yirik loyihalar uchun muhandislik yondashuvi." />
  <meta property="twitter:image"       content="https://swiftgenius.uz/summery_image.png" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body class="sg-body sg-mesh">
  <style is:global>
    /* 1. Global Reset & Performance */
    html { scroll-behavior: smooth; }
    .sg-body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: #000000;
      color: #FFFFFF;
      margin: 0;
      -webkit-font-smoothing: antialiased;
    }

    /* 2. Global Card Container Style */
    .sg-glass-card {
      background: linear-gradient(145deg, rgba(168, 85, 247, 0.05) 0%, rgba(0, 0, 0, 0.8) 100%);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(168, 85, 247, 0.3);
      border-radius: 40px;
      box-shadow: 0 0 50px rgba(168, 85, 247, 0.08);
      position: relative;
      overflow: hidden;
      padding: 3rem;
    }
    @media (max-width: 768px) {
      .sg-glass-card { border-radius: 24px; padding: 1.5rem; }
    }

    /* 3. Mentor Section */
    .mentor-photo-wrap {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      transform: scale(1.15);
      z-index: 10;
    }
    .mentor-photo-wrap::before {
      content: '';
      position: absolute;
      inset: -60px;
      background: radial-gradient(circle, rgba(168, 85, 247, 0.25) 0%, transparent 70%);
      filter: blur(50px);
      z-index: -1;
      pointer-events: none;
    }
    .mentor-photo-img {
      position: relative;
      z-index: 2;
      width: 100%;
      max-width: 500px;
      border-radius: 30px;
    }

    /* 4. Mission Section */
    .mission-card {
      background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, transparent 100%);
      border-left: 4px solid #A855F7;
      padding: 2rem;
      transition: 0.3s;
    }
    .target-badge {
      background: rgba(168, 85, 247, 0.1);
      border: 1px solid rgba(168, 85, 247, 0.4);
      color: #A855F7;
      padding: 0.5rem 1.5rem;
      border-radius: 99px;
      font-weight: 800;
      display: inline-block;
    }
    .feature-icon-box {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, #A855F7 0%, #6366f1 100%);
      border-radius: 10px;
      margin-bottom: 1.5rem;
      box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
    }

    /* 5. Curriculum */
    .module-card {
      background: rgba(10, 10, 10, 0.95);
      border: 1px solid rgba(168, 85, 247, 0.3);
      border-radius: 24px;
      padding: 1.5rem 2rem;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      margin-bottom: 1rem;
      box-shadow: 0 0 40px rgba(255,255,255,0.02);
    }
    @media (min-width: 768px) {
      .module-card { border-color: rgba(168, 85, 247, 0.4); padding: 2.5rem; }
    }
    .module-card:hover {
      background: rgba(168, 85, 247, 0.02);
      border-color: rgba(168, 85, 247, 0.5);
      transform: translateY(-2px);
    }
    .module-card.active {
      background: rgba(168, 85, 247, 0.04);
      border-color: rgba(168, 85, 247, 0.6);
    }
    .content-wrapper {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .module-card.active .content-wrapper {
      max-height: 2000px;
      opacity: 1;
      padding-top: 1.5rem;
      padding-bottom: 0.5rem;
    }

    /* 6. Big Picture */
    .arch-img-shadow {
      max-height: 450px !important;
      width: auto !important;
      object-fit: contain;
      filter: drop-shadow(0 0 40px rgba(168, 85, 247, 0.25));
      transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    @media (max-width: 768px) {
      .arch-img-shadow { max-height: 300px !important; }
    }
    .big-picture-tag {
      background: rgba(168, 85, 247, 0.1);
      border: 1px solid rgba(168, 85, 247, 0.4);
      color: #A855F7;
      padding: 6px 16px;
      border-radius: 99px;
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    /* 7. CTA Final */
    .cta-final-wrapper {
      background: radial-gradient(circle at center, rgba(168, 85, 247, 0.12) 0%, #000 100%);
      position: relative;
      padding: 120px 20px 0;
      min-height: 600px;
      display: flex;
      align-items: center;
    }
    .mentor-display-img {
      display: block !important;
      line-height: 0 !important;
      margin-bottom: 0 !important;
      padding-bottom: 0 !important;
    }

    /* 8. Utilities */
    .sg-btn-gradient {
      background: linear-gradient(135deg, #A855F7 0%, #6366f1 100%);
      color: white;
      font-weight: 800;
      transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .sg-btn-gradient:hover {
      transform: translateY(-3px) scale(1.02);
      box-shadow: 0 15px 30px rgba(168, 85, 247, 0.4);
    }
    .sg-scroll-in {
      opacity: 0;
      transform: translateY(40px);
      transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .sg-visible {
      opacity: 1 !important;
      transform: translateY(0) !important;
    }

    /* 9. Navbar */
    .nav-link {
      position: relative;
      padding: 0.4rem 0.6rem;
      font-size: 0.75rem;
      font-weight: 800;
      color: rgba(255, 255, 255, 0.4);
      text-decoration: none;
      transition: all 0.3s ease;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      white-space: nowrap;
    }
    @media (max-width: 1200px) {
      .nav-link { padding: 0.4rem 0.4rem; font-size: 0.7rem; }
    }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 10%;
      width: 0;
      height: 2px;
      background: #A855F7;
      box-shadow: 0 0 8px #A855F7;
      transition: width 0.3s ease;
    }
    .nav-link.active { color: #ffffff; }
    .nav-link.active::after { width: 80%; }
    .nav-btn {
      background: linear-gradient(135deg, #A855F7 0%, #6366f1 100%);
      color: white;
      padding: 8px 16px;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 900;
      text-transform: uppercase;
      text-decoration: none;
      transition: 0.3s;
      flex-shrink: 0;
    }
    .nav-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(168, 85, 247, 0.3);
    }
    #mobile-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }
    .menu-open #path1 { transform: translateY(6px) rotate(45deg); transform-origin: center; }
    .menu-open #path2 { opacity: 0; }
    .menu-open #path3 { transform: translateY(-6px) rotate(-45deg); transform-origin: center; }

    /* 10. Language Toggle */
    .lang-toggle {
      display: inline-flex;
      align-items: center;
      border: 1px solid rgba(168, 85, 247, 0.35);
      border-radius: 99px;
      overflow: hidden;
      background: rgba(168, 85, 247, 0.05);
      flex-shrink: 0;
    }
    .lang-toggle button {
      padding: 5px 12px;
      font-size: 0.7rem;
      font-weight: 900;
      letter-spacing: 0.05em;
      border: none;
      background: transparent;
      color: rgba(255,255,255,0.35);
      cursor: pointer;
      transition: all 0.25s ease;
      text-transform: uppercase;
      line-height: 1;
    }
    .lang-toggle button.lang-active {
      background: linear-gradient(135deg, #A855F7 0%, #6366f1 100%);
      color: #fff;
      border-radius: 99px;
      margin: 2px;
      box-shadow: 0 0 12px rgba(168,85,247,0.4);
    }
    .lang-toggle button:hover:not(.lang-active) {
      color: rgba(255,255,255,0.7);
    }
  </style>

  <!-- ═══════════════════════════════════════════════════════ NAVBAR ═══ -->
  <nav class="fixed top-0 left-0 right-0 z-[100] border-b border-white/5 bg-black/80 backdrop-blur-xl">
    <div class="max-w-[1440px] mx-auto px-4 md:px-6 h-16 md:h-20 flex items-center justify-between">

      <!-- Logo -->
      <a href="#" class="flex items-center gap-2 no-underline z-[110]">
        <img src="/brend_logo.png" alt="Logo" class="h-6 md:h-8 w-auto" />
        <span class="text-white font-[950] text-base md:text-lg tracking-tighter italic whitespace-nowrap">SWIFT GENIUS</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1 xl:gap-2">
        <a href="#mentor"             class="nav-link">{t.nav.author}</a>
        <a href="#mission"            class="nav-link">{t.nav.mission}</a>
        <a href="#curriculum"         class="nav-link">{t.nav.curriculum}</a>
        <a href="#final-picture"      class="nav-link">{t.nav.architecture}</a>
        <a href="#modular-architecture" class="nav-link">RIBs</a>
        <a href="#expected-outcome"   class="nav-link">{t.nav.outcome}</a>
        <a href="#faq"                class="nav-link">FAQ</a>
        <a href="#contact"            class="nav-link">{t.nav.contact}</a>

        <!-- Lang toggle (desktop) -->
        <div class="lang-toggle ml-2" id="lang-toggle-desktop">
          <button data-lang="uz" class={isEn ? '' : 'lang-active'}>🇺🇿 UZ</button>
          <button data-lang="en" class={isEn ? 'lang-active' : ''}>🇬🇧 EN</button>
        </div>

        <a href="https://t.me/iosDev007" target="_blank" class="nav-btn ml-2">
          {t.nav.enroll}
        </a>
      </div>

      <!-- Hamburger -->
      <button id="menu-toggle" class="lg:hidden z-[110] text-white p-2 focus:outline-none" aria-label="Toggle menu">
        <svg id="menu-icon" class="w-7 h-7 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="path1" class="origin-center transition-all duration-300" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16"/>
          <path id="path2" class="origin-center transition-all duration-300" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12h16"/>
          <path id="path3" class="origin-center transition-all duration-300" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile overlay -->
    <div id="mobile-overlay" class="fixed inset-0 bg-black/95 z-[105] flex flex-col items-center justify-center gap-6 opacity-0 pointer-events-none transition-all duration-500 overflow-y-auto pt-20">
      <a href="#mentor"               class="text-white text-xl font-bold uppercase tracking-wider hover:text-purple-400 transition-colors">{t.nav.author}</a>
      <a href="#mission"              class="text-white text-xl font-bold uppercase tracking-wider hover:text-purple-400 transition-colors">{t.nav.mission}</a>
      <a href="#curriculum"           class="text-white text-xl font-bold uppercase tracking-wider hover:text-purple-400 transition-colors">{t.nav.curriculum}</a>
      <a href="#final-picture"        class="text-white text-xl font-bold uppercase tracking-wider hover:text-purple-400 transition-colors">{t.nav.architecture}</a>
      <a href="#modular-architecture" class="text-white text-xl font-bold uppercase tracking-wider hover:text-purple-400 transition-colors">RIBs</a>
      <a href="#expected-outcome"     class="text-white text-xl font-bold uppercase tracking-wider hover:text-purple-400 transition-colors">{t.nav.outcome}</a>
      <a href="#faq"                  class="text-white text-xl font-bold uppercase tracking-wider hover:text-purple-400 transition-colors">FAQ</a>
      <a href="#contact"              class="text-white text-xl font-bold uppercase tracking-wider hover:text-purple-400 transition-colors">{t.nav.contact}</a>

      <!-- Lang toggle (mobile) -->
      <div class="lang-toggle" id="lang-toggle-mobile">
        <button data-lang="uz" class={isEn ? '' : 'lang-active'}>🇺🇿 UZ</button>
        <button data-lang="en" class={isEn ? 'lang-active' : ''}>🇬🇧 EN</button>
      </div>

      <a href="https://t.me/iosDev007" target="_blank" class="sg-btn-gradient text-lg px-8 py-4 mt-4 no-underline text-white font-bold rounded-xl text-center">
        {t.nav.enroll}
      </a>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════════════ HERO ═══ -->
  <section class="min-h-screen flex items-center px-4 md:px-6 pt-24 md:pt-20 overflow-hidden relative bg-black">
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-purple-600/10 blur-[150px] rounded-full"></div>
      <div class="absolute bottom-[10%] right-[5%] w-[30%] h-[30%] bg-purple-800/5 blur-[120px] rounded-full"></div>
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center w-full relative z-10">
      <div class="sg-scroll-in sg-visible text-center lg:text-left order-2 lg:order-1">
        <div class="inline-block px-6 py-2 mb-6 rounded-full border border-purple-500/30 bg-purple-500/10 text-purple-400 text-xs md:text-sm font-black tracking-[0.2em] uppercase">
          {t.hero.badge}
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.1] bg-gradient-to-b from-white to-purple-500/30 bg-clip-text text-transparent mb-6 italic uppercase tracking-tighter">
          {t.hero.title}
        </h1>
        <p class="text-gray-400 text-lg md:text-xl mb-10 max-w-xl mx-auto lg:mx-0 leading-relaxed italic">
          {t.hero.desc1} <span class="text-white">{t.hero.desc2}</span> {t.hero.desc3}<span class="text-white">{t.hero.desc4}</span>
        </p>
        <div class="flex justify-center lg:justify-start">
          <a href="#mentor" class="sg-btn-gradient text-lg md:text-xl px-8 md:px-10 py-4 md:py-5 rounded-2xl">
            {t.hero.cta}
          </a>
        </div>
      </div>

      <div class="flex justify-center lg:justify-end relative order-1 lg:order-2">
