  /* 3. Mentor & Education Refactor */
 
 .mentor-photo-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  transform: scale(1.15);
  z-index: 10;
}

.mentor-photo-wrap::before {
  content: '';
  position: absolute;
  inset: -60px;
  background: radial-gradient(circle, rgba(168, 85, 247, 0.25) 0%, transparent 70%);
  filter: blur(50px); /* Nurni yumshatish uchun muhim */
