---
import '../styles/global.css';
const education = [
  { name: "Swift Academy" },
  { name: "PDP Academy" },
  { name: "Essential Developer Academy" },
  { name: "Swiftful Thinking" }
];
const modules = [
  {
    num: '01',
    category: 'SwiftUI Foundations',
    title: 'UI Elements, State & Navigation',
    subsections: [
      {
        head: 'UI Elements & Modifiers',
        items: ['Text, Image, Button, Spacer', 'VStack, HStack, ZStack', 'padding, frame, alignment', 'background, overlay']
      },
      {
        head: 'State va Data Flow',
        items: ['@State, @Binding, @Bindable', '@StateObject, @ObservedObject', '@ObservableObject, @Published', '@EnvironmentObject, @Environment']
      },
      {
        head: 'Lists va Dynamic UI',
        items: ['List, ScrollView, ForEach', 'LazyVStack, LazyHStack', 'CustomView, ViewModifier']
      },
      {
        head: 'Navigation & Presentation',
        items: ['NavigationStack, NavigationPath', 'navigationDestination', 'sheet, fullScreenCover, Alert']
      }
    ]
  },
  {
    num: '02',
    category: 'Application Structure',
    title: 'App Lifecycle & Flow Architecture',
    subsections: [
      {
        head: "App Architecture & Lifecycle",
        items: ["App protocol, @main", "Scene, WindowGroup", "UIKit AppDelegate implementation", "Practical: Lifecycle-driven management"]
      },
      {
        head: "Application Flow Architecture",
        items: ["RootView logic & Navigation State", "App Flow Controller (Splash → Auth → Main)", "Modular Feature Flows", "Deep Linking foundations"]
      }
    ]
  },
  {
    num: '03',
    category: 'Architecture',
    title: 'MVVM Architecture & SoC',
    subsections: [
      {
        head: "MVVM Architecture",
        items: ["View, ViewModel, Model Roles", "Business Logic Separation", "Data Binding Techniques", "Separation of Concerns (SoC)"]
      }
    ]
  },
  {
    num: '04',
    category: 'Software Engineering',
    title: 'Dependency Injection & POP',
    subsections: [
      {
        head: "Dependency Injection (DI)",
        items: ["Inversion of Control (IoC)", "Loose Coupling principles", "DI Container architecture", "Service registration & resolution"]
      },
      {
        head: "Protocol-Oriented Programming (POP)",
        items: ["Abstraction & Interface Design", "Swappability & Decoupling", "Enhanced Testability architecture"]
      }
    ]
  },
  {
    num: '05',
    category: 'Global Architecture',
    title: 'Global Managers & SOLID',
    subsections: [
      {
        head: "Global Managers & Service Architecture",
        items: ["Composite & Delegation patterns", "Decoupling Massive Managers", "SOLID Principles application", "Environment Dependency Injection"]
      }
    ]
  },
  {
    num: '06',
    category: 'Business Logic',
    title: 'Interactor Layer & Refactoring',
    subsections: [
      {
        head: "Interactor & Business Logic Architecture",
        items: ["Domain Logic Separation", "ViewModel to Interactor Interaction", "Unidirectional Data Flow"]
      },
      {
        head: "Centralized global Business Logic",
        items: ["Global Business Layer orchestration", "Global State Synchronization", "Service Management & Abstraction"]
      },
      {
        head: "CoreInteractor: Refactoring",
        items: ["Interface Segregation", "Breaking down Monolithic Logic", "Dependency Optimization"]
      }
    ]
  },
  {
    num: '07',
    category: 'Core Application',
    title: 'CoreBuilder & Composition Root',
    subsections: [
      {
        head: "CoreBuilder & Composition Root",
        items: ["Composition Root Pattern", "Centralized Component Initialization", "Object Graph Construction"]
      },
      {
        head: "CoreBuilder: Refactoring",
        items: ["Composition Root Optimization", "Architecture Simplification", "Streamlining Dependency Assembly"]
      }
    ]
  },
  {
    num: '08',
    category: 'Navigation Architecture',
    title: 'CoreRouter & Routing Patterns',
    subsections: [
      {
        head: "Navigation Architecture & CoreRouter",
        items: ["CoreRouter Architecture", "ViewModel to Router Communication", "Decoupling Navigation from UI"]
      },
      {
        head: "Navigation Refactoring",
        items: ["Navigation Logic Centralization", "Global Router Migration Strategy", "Dynamic Flow Management"]
      }
    ]
  },
  {
    num: '09',
    category: 'Environment',
    title: 'Environment & Build Configuration',
    subsections: [
      {
        head: "Environment & Build Configuration",
        items: ["Dev, Release & Mock Schemes", "Build Configuration Management", "Scheme-based Environment Switching"]
      }
    ]
  },
  {
    num: '10',
    category: 'Production Features',
    title: 'Analytics, Security & Localization',
    subsections: [
      {
        head: "Logging & Diagnostics",
        items: ["Centralized AppLogger", "Diagnostic Log Levels", "Unified Logging Strategy"]
      },
      {
        head: "Analytics & Crashlytics",
        items: ["Firebase & Mixpanel Integration", "Facade Pattern for Analytics", "Behavioral Tracking events"]
      },
      {
        head: "App Security & Protected UI",
        items: ["Privacy-preserving UI (Blur Overlay)", "DeepLink Security", "Sensitive Data Protection"]
      },
      {
        head: "Language & Theme Architecture",
        items: ["Scalable Localization", "AppLocalModifier & AppThemeModifier", "Dynamic Environment Sync"]
      }
    ]
  },
  {
    num: '11',
    category: 'Advanced Engineering',
    title: 'Modular Architecture & RIBs',
    subsections: [
      {
        head: "Architectural Decomposition",
        items: ["Modular Architecture (Feature separation)", "RIBs (Router, Interactor, Builder)", "System Design for Large-Scale"]
      },
      {
        head: "Scalability & Isolation",
        items: ["Decoupling Feature Modules", "Dependency Management in Modules", "Independent Feature Lifecycle"]
      }
    ]
  },
  {
    num: '12',
    category: 'Quality Assurance',
    title: 'Unit & UI Testing Strategies',
    subsections: [
      {
        head: "Unit Testing & QA",
        items: ["Isolated Business Logic verification", "Mock Services & Data Stubbing", "ViewModel State testing"]
      },
      {
        head: "UI Testing",
        items: ["XCUITest Framework", "Automated UI Flow Verification", "Multi-screen Navigation Testing"]
      }
    ]
  }
];

const faqs = [
  { 
    q: 'Swift bilmasam ham qo\'shilishim mumkinmi?', 
    a: 'Yo\'q, bu kurs fundamental Swift va SwiftUI boshlang\'ich bilimlarini talab qiladi. Agar sizda kamida 1 yillik iOS tajriba bo\'lsa yoki kuchli "Strong Junior" bo\'lsangiz, kurs siz uchun maksimal foydali bo\'ladi.' 
  },
  { 
    q: 'Darslar qanday formatda o\'tkaziladi?', 
    a: 'Darslar jonli (Live) formatda, onlayn yoki offlayn ko\'rinishda bo\'ladi. Faqat nazariya emas, balki kod review (kodni tahlil qilish), loyiha muhokamasi va mentor bilan real vaqtdagi arxitektura qarorlari ustuvorlik qiladi.' 
  },
  { 
    q: 'Kurs qancha davom etadi?', 
    a: 'Kurs murakkab modullar bo\'yicha tashkil etilgan. Har bir modulda real loyiha va amaliyot bor. O\'zlashtirish tezligiga qarab aniq muddat mentor bilan shaxsiy reja asosida belgilanadi.' 
  },
  { 
    q: 'Nega bu kursda o\'qishim kerak, AI orqali ham o\'rgansam bo\'ladiku?', 
    a: 'AI (ChatGPT/Claude) sizga kod bo\'laklarini yozib berishi mumkin, lekin u loyihaning to\'liq arxitektura zanjirini va jamoaviy ishlash madaniyatini o\'rgata olmaydi. Kursimizda biz AI qila olmaydigan ishni — o\'zgaruvchan talablarga moslashuvchan va barqaror tizim loyihalashni "Engineering Mindset" orqali amalda ko\'rib chiqamiz.' 
  },
  { 
    q: 'Bu kursda faqat chiroyli UI chizishni o\'rganamizmi?', 
    a: 'Yo\'q, bu kurs interfeys chizishga (UI) qaratilmagan. Bizning asosiy fokusimiz — har qanday murakkablikdagi ilovaga mos keladigan, "Production-Ready" darajasidagi mustahkam arxitektura (Architecture) qurishni o\'rganishdir. UI vaqtinchalik, lekin to\'g\'ri qurilgan arxitektura yillar davomida xizmat qiladi.' 
  },
  { 
    q: 'Loyiha arxitekturasini noldan qurishni o\'rganamanmi?', 
    a: 'Albatta. Kurs davomida bo\'sh varaqdan boshlab, qatlamlarga ajratilgan, modulli va barcha zamonaviy talablarga javob beradigan loyiha skeletini (Boilerplate) mentor bilan birga qurasiz.' 
  },
  { 
    q: 'Mentorlik va kod review qanchalik muhim?', 
    a: 'Bu kursning eng qimmatli qismi. Siz yozgan kod professional "Senior" ko\'zi bilan tahlil qilinadi. Qayerda xato qilganingiz, qaysi yondashuv kelajakda muammo tug\'dirishi mumkinligi va qanday qilib kodni yanada toza (Clean) qilish bo\'yicha shaxsiy maslahatlar olasiz.' 
  },
  { 
    q: 'Yirik kompaniyalarda aynan shu bilimlarni so\'rashadimi?', 
    a: 'Ha. Dubay, Yevropa va AQSHning top kompaniyalari (Uber, Grab, Revolut) aynan RIBs, Modularity va Unit Testing bo\'yicha chuqur bilimga ega iOS Engineerlarni qidirishadi. Bu kurs sizni global bozorga tayyorlaydi.' 
  },
  { 
    q: 'Sertifikat beriladimi?', 
    a: 'Ha, kursni muvaffaqiyatli tamomlagan va yakuniy arxitektura loyihasini himoya qilgan talabalarga SwiftGenius professional sertifikati taqdim etiladi.' 
  },
  { 
    q: 'Nega SwiftUI ishlatiladi?', 
    a: 'SwiftUI — bu iOS kelajagi. Biz deklarativ UI orqali interfeys qatlamini tezroq quramiz, lekin asosiy e\'tiborni uni biznes mantiqdan (RIBs orqali) qat\'iy ajratishga qaratamiz.' 
  },
  { 
    q: 'MVVM v RIBs: Qaysi biri yaxshiroq?', 
    a: 'MVVM kichik ilovalar uchun yaxshi, lekin RIBs navigatsiyani State-dan ajratgani uchun yirik (Enterprise) loyihalarda muvozanatni saqlaydi. Biz Senior muhandislar tanlaydigan RIBs tizimini chuqur o\'rgatamiz.' 
  },
  { 
    q: 'Unit Testing shartmi?', 
    a: 'Albatta! "Clean Code" va Senior darajasi testlarsiz tasavvur qilib bo\'lmaydi. Biz TDD elementlari orqali har bir yozilgan funksiyani barqarorligini ta\'minlashni o\'rgatamiz.' 
  },
  { 
    q: 'Modullashtirish (Modularity) nima beradi?', 
    a: 'Bu ilovani mustaqil bo\'laklarga ajratish san\'ati. Bu orqali Build vaqti kamayadi, kodni qayta ishlatish osonlashadi va yirik jamoalarda tartibli ishlash imkoniyati yaratiladi.' 
  },
  { 
    q: 'Dependency Injection (DI) kursda qanchalik chuqur o\'rgatiladi?', 
    a: 'DI — bu arxitekturaning asab tizimi. Biz IoC, konteynerlar va lifecycle management kabi Senior mavzularni RIBs builderlari misolida amalda ko\'rib chiqamiz.' 
  },
  { 
    q: 'Kursdan so\'ng men Senior bo\'lamanmi?', 
    a: 'Kurs sizga Senior muhandislik poydevorini (Arxitektura, Testing, Modular Design) beradi. Bu bilimlar bilan siz yirik kompaniyalarda arxitektor yoki jamoa yetakchisi sifatida ishlash darajasiga erishasiz.' 
  }
];

