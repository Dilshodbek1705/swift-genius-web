  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
  <body class="sg-body sg-mesh">
   <style is:global>
  /* 1. Global Reset & Performance */
  html { scroll-behavior: smooth; }
  .sg-body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background: #000000;
    color: #FFFFFF;
    margin: 0;
    -webkit-font-smoothing: antialiased;
  }


  /* 2. Hero Section Refined */
 .hero-title {
  font-size: clamp(2.5rem, 8vw, 4.5rem) !important; 
  line-height: 1.1 !important;
  font-weight: 900;
  letter-spacing: -0.05em;
  font-style: italic;
  color: #ffffff;
  white-space: normal !important; 
  width: 120% !important; 
  max-width: none !important;
  display: block;
  /* MANA SHU QATORNI QO'SHING YOKI YANGILANG */
  margin-bottom: 2.5rem !important; 
}

@media (max-width: 1023px) {
  .hero-title {
    width: 100% !important;
    font-size: 2.8rem !important;
    white-space: normal !important;
  }
}
  /* Hero Logo Majburiy Kichraytirish */
  .hero-logo-col img {
    width: 220px !important;
    height: auto !important;
    object-fit: contain;
    filter: drop-shadow(0 0 50px rgba(168, 85, 247, 0.4));
  }

  @media (max-width: 1023px) {
    .hero-title { white-space: normal; font-size: 3rem; }
    .hero-logo-col img { width: 180px !important; }
  }

  /* 3. Mentor & Education Refactor */
 
 .mentor-photo-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  transform: scale(1.15);
  z-index: 10;
}

.mentor-photo-wrap::before {
  content: '';
  position: absolute;
  inset: -60px;
  background: radial-gradient(circle, rgba(168, 85, 247, 0.25) 0%, transparent 70%);
  filter: blur(50px); /* Nurni yumshatish uchun muhim */
  z-index: -1; /* !!! MANA SHU: Nurni rasmning orqasiga o'tkazadi */
  pointer-events: none; /* Nur rasm ustidagi kliklarni to'smaydi */
}

.mentor-photo-img {
  position: relative; /* z-index ishlashi uchun kerak */
  z-index: 2; /* Rasmni nurdan balandga ko'taramiz */
  width: 100%;
  max-width: 500px;
  border-radius: 30px;
}


 /* 3. Credential & Education - Pro Refactor */
 
  .edu-card-pro {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 20px;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
.edu-section-title {
    font-size: 0.75rem;
    font-weight: 900 !important; /* Bold bo'lishini kafolatlaydi */
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #A855F7;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* Mission & Target Section Styles */
  .mission-card {
    background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, transparent 100%);
    border-left: 4px solid #A855F7;
    padding: 2rem;
    transition: 0.3s;
  }
  .target-badge {
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.4);
    color: #A855F7;
    padding: 0.5rem 1.5rem;
    border-radius: 99px;
    font-weight: 800;
    display: inline-block;
  }
  .feature-icon-box {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #A855F7 0%, #6366f1 100%);
    border-radius: 10px;
    margin-bottom: 1.5rem;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }

 .roadmap-wrapper {
    display: flex;
    gap: 2rem;
    padding: 2rem 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
  }
  .roadmap-wrapper::-webkit-scrollbar { display: none; } /* Chrome/Safari */

  .roadmap-step-card {
    min-width: 300px;
    height: 400px;
    scroll-snap-align: center;
    background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(168, 85, 247, 0.02) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 40px;
    padding: 2.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    cursor: grab;
  }

  /* Architecture & Design Section Styles */
  .arch-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 32px;
    padding: 3rem;
    transition: 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .arch-card:hover {
    border-color: rgba(168, 85, 247, 0.3);
    background: rgba(168, 85, 247, 0.02);
  }

  .arch-list-item {
    position: relative;
    padding-left: 4rem;
    margin-bottom: 3rem;
  }

  .arch-dot {
    position: absolute;
    left: 0;
    top: 0;
    width: 2.5rem;
    height: 2.5rem;
    border: 3px solid rgba(168, 85, 247, 0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .arch-dot::after {
    content: '';
    width: 0.8rem;
    height: 0.8rem;
    background: #A855F7;
    border-radius: 50%;
    box-shadow: 0 0 15px #A855F7;
  }

  .arch-icon-glow {
    filter: drop-shadow(0 0 30px rgba(168, 85, 247, 0.4));
  }

  /* Spotlight Effect */
  .roadmap-step-card:hover {
    border-color: rgba(168, 85, 247, 0.6);
    background: rgba(168, 85, 247, 0.05);
    transform: scale(1.02) translateY(-10px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 20px rgba(168, 85, 247, 0.2);
  }

  .step-index {
    font-size: 5rem;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(180deg, rgba(168, 85, 247, 0.2) 0%, transparent 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    position: absolute;
    top: 1rem;
    right: 2rem;
  }

  .glowing-path {
    position: absolute;
    top: 50%;
    left: 0;
    width: 200%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #A855F7, #6366f1, transparent);
    z-index: 0;
    opacity: 0.3;
    pointer-events: none;
  }



 /* 4. Interactive Curriculum - Spatial Refactor */
  .module-card {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 24px !important; /* Burchaklar biroz o'tkirroq, ixchamroq */
    padding: 1.5rem 2rem !important; /* Heightni kamaytirish uchun padding qisqartirildi */
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    margin-bottom: 1rem;
  }

  .module-card:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(168, 85, 247, 0.4);
    transform: translateY(-2px); /* Katta sakrash emas, nafis ko'tarilish */
  }

  .module-card.active {
    background: rgba(168, 85, 247, 0.03);
    border-color: rgba(168, 85, 247, 0.6);
  }

  /* Font o'lchamlarini normallashtirish */
  .module-number {
    font-size: 1.8rem !important; /* 3.5rem juda katta edi */
    font-weight: 800;
    opacity: 0.25;
    background: linear-gradient(135deg, #fff, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    width: 60px;
  }

  .module-title {
    font-size: 1.25rem !important; /* Desktop uchun ideal sarlavha o'lchami */
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .category-tag {
    font-size: 9px !important; /* Juda kichik, lekin o'qiladigan "eyecandy" */
    letter-spacing: 0.15em;
    color: #a855f7;
    font-weight: 800;
    margin-bottom: 2px;
  }

  /* Kontent ochilgandagi o'lchamlar */
  .content-wrapper {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .module-card.active .content-wrapper {
    max-height: 1500px;
    opacity: 1;
    padding-top: 1.5rem;
    padding-bottom: 0.5rem;
  }

  /* Section Title normallashtirish */
  .section-title-main {
    font-size: clamp(2rem, 5vw, 3.5rem) !important;
    line-height: 1;
    margin-bottom: 1rem;
  }
    /* 4. Interactive Curriculum tugadi */

/* Final Big Picture Section */
  .arch-display-container {
    background: radial-gradient(circle at center, rgba(168, 85, 247, 0.15) 0%, transparent 70%);
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 4rem;
    position: relative;
    overflow: hidden;
  }

  .arch-img-shadow {
    filter: drop-shadow(0 0 50px rgba(168, 85, 247, 0.3));
    transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .arch-display-container:hover .arch-img-shadow {
    transform: scale(1.02) translateY(-10px);
  }

  .big-picture-tag {
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.4);
    color: #A855F7;
    padding: 6px 16px;
    border-radius: 99px;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  /* Rasm konteynerini balandligini jilovlash */
  .arch-display-container {
    background: radial-gradient(circle at center, rgba(168, 85, 247, 0.12) 0%, transparent 70%);
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 3rem 4rem; /* Padding biroz kamaytirildi */
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .arch-img-shadow {
    /* Balandlikni cheklash uchun max-height qo'shildi */
    max-height: 450px !important; 
    width: auto !important; /* Kenglik avtomat o'zi moslashadi */
    object-fit: contain;
    filter: drop-shadow(0 0 40px rgba(168, 85, 247, 0.25));
    transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* Mobil qurilmalar uchun yana biroz kichiklashtiramiz */
  @media (max-width: 768px) {
    .arch-img-shadow {
      max-height: 300px !important;
    }
    .arch-display-container {
      padding: 2rem;
    }
  }

 /* Final Outcome - Card Style */
  .outcome-card {
    background: #080808; /* To'q fon */
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 40px;
    padding: 4rem;
    position: relative;
    overflow: hidden;
  }

  .outcome-bullet {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .bullet-circle {
    width: 2.5rem;
    height: 2.5rem;
    border: 2px solid rgba(168, 85, 247, 0.4);
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.25rem;
  }

  .bullet-dot {
    width: 0.8rem;
    height: 0.8rem;
    background: #A855F7;
    border-radius: 50%;
    box-shadow: 0 0 15px #A855F7;
  }

  .outcome-title-main {
    font-size: 5rem;
    line-height: 0.9;
    font-weight: 950;
    font-style: italic;
    letter-spacing: -0.05em;
    color: #fff;
  }

  .outcome-subtitle {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .outcome-desc {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
    max-width: 500px;
  }
  /* Final Call to Action Styles */
  .cta-final-wrapper {
    background: radial-gradient(circle at center, rgba(168, 85, 247, 0.12) 0%, #000 100%);
    position: relative;
    padding: 120px 20px;
    min-height: 600px;
    display: flex;
    align-items: center;
  }

  /* O'ng tarafdagi kontent ierarxiyasi */
  .cta-right-content {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
