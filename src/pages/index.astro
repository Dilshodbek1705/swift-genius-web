  pointer-events: none; /* Nur rasm ustidagi kliklarni to'smaydi */
}

.mentor-photo-img {
  position: relative; /* z-index ishlashi uchun kerak */
  z-index: 2; /* Rasmni nurdan balandga ko'taramiz */
  width: 100%;
  max-width: 500px;
  border-radius: 30px;
}


 /* 3. Credential & Education - Pro Refactor */
 
  .edu-card-pro {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 20px;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
.edu-section-title {
    font-size: 0.75rem;
    font-weight: 900 !important; /* Bold bo'lishini kafolatlaydi */
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #A855F7;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* Mission & Target Section Styles */
  .mission-card {
    background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, transparent 100%);
    border-left: 4px solid #A855F7;
    padding: 2rem;
    transition: 0.3s;
  }
  .target-badge {
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.4);
    color: #A855F7;
    padding: 0.5rem 1.5rem;
    border-radius: 99px;
    font-weight: 800;
    display: inline-block;
  }
  .feature-icon-box {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #A855F7 0%, #6366f1 100%);
    border-radius: 10px;
    margin-bottom: 1.5rem;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }

 .roadmap-wrapper {
    display: flex;
    gap: 2rem;
    padding: 2rem 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
  }
  .roadmap-wrapper::-webkit-scrollbar { display: none; } /* Chrome/Safari */

  .roadmap-step-card {
    min-width: 300px;
    height: 400px;
    scroll-snap-align: center;
    background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(168, 85, 247, 0.02) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 40px;
    padding: 2.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    cursor: grab;
  }

  /* Architecture & Design Section Styles */
  .arch-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 32px;
    padding: 3rem;
    transition: 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .arch-card:hover {
    border-color: rgba(168, 85, 247, 0.3);
    background: rgba(168, 85, 247, 0.02);
  }

  .arch-list-item {
    position: relative;
    padding-left: 4rem;
    margin-bottom: 3rem;
  }

  .arch-dot {
    position: absolute;
    left: 0;
    top: 0;
    width: 2.5rem;
    height: 2.5rem;
    border: 3px solid rgba(168, 85, 247, 0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .arch-dot::after {
    content: '';
    width: 0.8rem;
    height: 0.8rem;
    background: #A855F7;
    border-radius: 50%;
    box-shadow: 0 0 15px #A855F7;
  }

  .arch-icon-glow {
    filter: drop-shadow(0 0 30px rgba(168, 85, 247, 0.4));
  }

  /* Spotlight Effect */
  .roadmap-step-card:hover {
    border-color: rgba(168, 85, 247, 0.6);
    background: rgba(168, 85, 247, 0.05);
    transform: scale(1.02) translateY(-10px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 20px rgba(168, 85, 247, 0.2);
  }

  .step-index {
    font-size: 5rem;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(180deg, rgba(168, 85, 247, 0.2) 0%, transparent 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    position: absolute;
    top: 1rem;
    right: 2rem;
  }

  .glowing-path {
    position: absolute;
    top: 50%;
    left: 0;
    width: 200%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #A855F7, #6366f1, transparent);
    z-index: 0;
    opacity: 0.3;
    pointer-events: none;
  }



 /* 4. Interactive Curriculum - Spatial Refactor */
  .module-card {
