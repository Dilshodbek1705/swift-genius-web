---
// src/components/Mentor.astro
import type { Translations } from '../i18n/index.ts';
import { getMentorProjects, EDUCATION } from '../data/mentor.ts';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const mentorProjects = getMentorProjects(t);
---

<section id="mentor" class="py-12 md:py-24 px-4 md:px-6 bg-[#050505]">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <div class="flex justify-center lg:justify-start lg:pr-12 order-1">
        <div class="mentor-photo-wrap relative">
          <div class="absolute inset-0 bg-purple-600/10 blur-[60px] rounded-full"></div>
          <img src="/brend_me.png" alt="Dilshodbek Qulmirzayev" class="mentor-photo-img" />
        </div>
      </div>

      <div class="space-y-8 md:space-y-10 order-2 sg-scroll-in">
        <div class="text-center lg:text-left">
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight mb-3 italic text-white uppercase">
            Dilshodbek <br class="hidden md:block"/> Qulmirzayev
          </h2>
          <p class="text-xl md:text-2xl text-purple-400 font-bold">iOS Engineer, TUNE Consulting</p>
        </div>

        <div>
          <h3 class="text-xs font-black uppercase tracking-[0.25em] text-purple-500 mb-6 border-b border-white/10 pb-3 flex items-center gap-3">
            {t.mentor.education}
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 mb-10">
            {EDUCATION.map(edu => (
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-purple-500 shadow-[0_0_8px_#A855F7]"></span>
                <span class="font-bold text-gray-300 text-sm md:text-base">{edu}</span>
              </div>
            ))}
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {mentorProjects.map((p) => (
              <a
                href={p.href}
                target={p.href ? "_blank" : undefined}
                class={`flex items-center gap-3 p-3 bg-[#0a0a0a] rounded-2xl border border-purple-500/20 transition-all group shadow-sm
                  ${!p.href ? 'pointer-events-none opacity-80' : 'hover:border-purple-500/60 hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(168,85,247,0.15)]'}`}
              >
                <div class="flex items-center gap-3 w-full transition-all">
                  <img src={p.logo} class={`w-10 h-10 md:w-12 md:h-12 rounded-xl object-contain shadow-lg ${!p.href ? 'grayscale' : ''}`} alt={p.name} />
                  <div class="min-w-0 text-left">
                    <span class="text-white font-bold block truncate group-hover:text-purple-400 transition text-sm md:text-base">{p.name}</span>
                    <span class={`text-[10px] uppercase tracking-wider ${!p.href ? 'text-purple-500 font-bold' : 'text-gray-500'}`}>
                      {p.badge || 'App Store →'}
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
