---
// src/components/Outcome.astro
import type { Translations } from '../i18n/index.ts';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="expected-outcome" class="py-16 md:py-24 px-4 md:px-6 bg-black relative">
  <div class="max-w-6xl mx-auto">
    <div class="sg-glass-card sg-scroll-in">
      <div class="absolute inset-0 bg-purple-600/[0.03] blur-[100px] md:blur-[120px] rounded-full pointer-events-none"></div>
      <div class="relative z-10">
        <div class="mb-12 md:mb-16 text-center">
          <h2 class="text-3xl md:text-5xl lg:text-6xl font-[950] italic tracking-tighter leading-none text-white uppercase">
            {t.outcome.title1} <span class="text-purple-500">{t.outcome.title2}</span>
          </h2>
        </div>
        <ul class="space-y-8 md:space-y-10 text-gray-300">
          {t.outcomeList.map((item) => (
            <li class="flex items-start gap-4 md:gap-6 group">
              <span class="text-purple-500 text-xl md:text-2xl leading-none mt-1 shrink-0">●</span>
              <div>
                <h3 class="text-lg md:text-2xl font-bold text-white italic group-hover:text-purple-400 transition mb-2 uppercase">{item.title}</h3>
                <p class="text-sm md:text-lg leading-relaxed text-gray-400">{item.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
