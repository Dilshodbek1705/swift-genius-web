---
// src/components/ModularArchitecture.astro  (RIBs)
import type { Translations } from '../i18n/index.ts';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="modular-architecture" class="py-12 md:py-24 px-4 md:px-6 bg-[#050505] relative">
  <div class="max-w-6xl mx-auto">
    <div class="sg-glass-card sg-scroll-in">
      <div class="absolute -left-20 -bottom-20 w-full h-full bg-purple-600/[0.06] blur-[80px] md:blur-[120px] rounded-full pointer-events-none"></div>
      <div class="mb-8 md:mb-12 relative z-10 text-center md:text-left">
        <div class="mb-4 md:mb-6"><span class="big-picture-tag">Advanced Concepts</span></div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-[950] italic tracking-tighter leading-[1.1] mb-6 text-white uppercase">
          Scalable <span class="text-purple-500"> RIBs-based</span> <br class="hidden md:block" /> Modular Architecture
        </h2>
      </div>
      <div class="relative z-10 flex justify-center items-center mb-10 md:mb-16">
        <img src="/ribArch.png" alt="RIBs Architecture" class="arch-img-shadow" />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 border-t border-purple-500/20 pt-8 relative z-20">
        <div class="flex flex-col items-center md:items-start text-center md:text-left">
          <span class="text-white font-bold text-base md:text-lg mb-1">Deep Link Support</span>
          <p class="text-xs text-gray-400 italic">{t.ribs.deepLink}</p>
        </div>
        <div class="flex flex-col items-center md:items-start text-center md:text-left border-y md:border-y-0 md:border-x border-purple-500/20 py-6 md:py-0 md:px-6">
          <span class="text-white font-bold text-base md:text-lg mb-1">Business Logic First</span>
          <p class="text-xs text-gray-400 italic">{t.ribs.businessLogic}</p>
        </div>
        <div class="flex flex-col items-center md:items-start text-center md:text-left md:pl-6">
          <span class="text-white font-bold text-base md:text-lg mb-1">Extreme Isolation</span>
          <p class="text-xs text-gray-400 italic">{t.ribs.extremeIsolation}</p>
        </div>
      </div>
    </div>
  </div>
</section>
