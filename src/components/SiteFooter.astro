---
// src/components/SiteFooter.astro
import type { Translations } from '../i18n/index.ts';
import { SOCIALS } from '../data/mentor.ts';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<footer id="contact" class="relative py-20 md:py-32 px-4 md:px-6 bg-black overflow-hidden border-t border-white/5">
  <div class="absolute bottom-[-10%] left-1/2 -translate-x-1/2 w-[300px] md:w-[800px] h-[300px] md:h-[600px] bg-purple-600/20 blur-[100px] md:blur-[150px] rounded-full pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="flex flex-col items-center justify-center text-center mb-16 md:mb-20 sg-scroll-in">
      <h2 class="text-5xl md:text-6xl lg:text-7xl text-white font-[950] italic tracking-tighter leading-[1.1] uppercase">
        {t.footer.title1} <br/> <span class="text-purple-500">{t.footer.title2}</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 md:gap-8 w-full max-w-4xl mx-auto mb-16 md:mb-24 sg-scroll-in">
      {SOCIALS.map(social => (
        <a href={social.href} target="_blank"
          class={`group rounded-3xl p-6 md:p-8 flex flex-col items-center justify-center transition-all duration-300 bg-[#0a0a0a] border border-purple-500/30 ${social.color} hover:-translate-y-2 shadow-[0_0_30px_rgba(168,85,247,0.05)] hover:shadow-[0_0_40px_rgba(168,85,247,0.15)]`}>
          <div class="w-14 h-14 md:w-20 md:h-20 mb-4 md:mb-6 transform transition-transform duration-300 group-hover:scale-110">
            <img src={social.logo} class="w-full h-full object-contain" alt={social.name} />
          </div>
          <span class="text-gray-400 font-bold text-sm md:text-base tracking-wide group-hover:text-white transition-colors duration-300">{social.name}</span>
        </a>
      ))}
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between pt-8 border-t border-purple-500/20 gap-6">
      <div class="flex items-center gap-4">
        <img src="/brend_logo.png" class="h-8 md:h-10 w-auto" alt="Logo" />
        <div class="flex flex-col text-left">
          <span class="font-black italic tracking-tighter text-lg md:text-xl leading-none text-white uppercase">Swift Genius</span>
          <span class="text-[9px] md:text-[10px] text-purple-500 font-bold tracking-[0.3em] uppercase mt-1">iOS Academy</span>
        </div>
      </div>
    </div>
  </div>
</footer>
