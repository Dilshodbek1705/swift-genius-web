---
// src/components/FinalCta.astro
// Yakuniy "Join" chaqiruvi (statik matn, tarjima talab qilmaydi).
---

<section class="cta-final-wrapper">
  <div class="max-w-7xl mx-auto w-full px-4 md:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 items-center gap-10 lg:gap-40">
      <div class="sg-scroll-in flex flex-col items-center lg:items-start text-center lg:text-left lg:-translate-y-20">
        <h2 class="text-5xl md:text-6xl lg:text-7xl text-white font-[950] italic tracking-tighter leading-[1.2] uppercase mb-10 md:mb-16">
          Level up <br/>
          <span class="text-purple-500 whitespace-nowrap">Your Engineering</span>
        </h2>
        <div class="flex items-center gap-6">
          <h2 class="text-4xl md:text-5xl lg:text-6xl text-purple-500 whitespace-nowrap font-[950] italic tracking-tighter uppercase leading-none m-0">
            Now:
          </h2>
          <a href="https://t.me/iosDev007" target="_blank" class="sg-btn-gradient text-2xl md:text-4xl px-10 py-4 rounded-3xl tracking-wide">
            Join
          </a>
        </div>
      </div>
      <div class="flex justify-center lg:justify-end relative h-full self-end">
        <div class="absolute inset-0 bg-purple-600/20 blur-[80px] md:blur-[120px] rounded-full translate-y-10 pointer-events-none"></div>
        <img src="/my_photo.png" alt="Dilshodbek Qulmirzayev"
          class="relative z-10 w-full max-w-[350px] md:max-w-[450px] lg:max-w-[500px] mentor-display-img object-contain" />
      </div>
    </div>
  </div>
</section>
